# ═══════════════════════════════════════════════════════════════════════════════
# NEXUS Environment Variables
# Copy this file to .env.local and fill in your actual values
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Supabase Configuration ──────────────────────────────────────────────────────
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# I3 — Supabase connection pooler (pgBouncer)
# Use for direct Postgres connections (Prisma, Drizzle, pg) — NOT for supabase-js REST client
# Get from: Supabase Dashboard → Settings → Database → Connection Pooling
# SUPABASE_DATABASE_URL=postgresql://postgres.YOUR_PROJECT:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# SUPABASE_DIRECT_URL=postgresql://postgres.YOUR_PROJECT:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ─── Anthropic (Claude Haiku) ────────────────────────────────────────────────────
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-v0-...

# ─── Google Places API (Optional) ────────────────────────────────────────────────
# Get from https://console.cloud.google.com/
# Only needed if you want Google Places clinic data
# NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=AIzaSy...

# ─── Email Service (Optional) ────────────────────────────────────────────────────
# Get from https://resend.com/
# Only needed for cron job digest emails
# RESEND_API_KEY=re_...

# ─── Vercel Configuration ────────────────────────────────────────────────────────
# Set during Vercel deployment
CRON_SECRET=your-random-secret-key-for-cron-jobs
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
# I2 — app version string injected at build time (used by Sentry release tracking)
NEXT_PUBLIC_APP_VERSION=nexus@1.0.0

# ─── Push Notifications — VAPID keys (F3) ────────────────────────────────────────
# Generate a VAPID key pair: npx web-push generate-vapid-keys
# NEXT_PUBLIC prefix means this key is safe to expose to the browser
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BExamplePublicKey...
VAPID_PRIVATE_KEY=ExamplePrivateKey...
VAPID_SUBJECT=mailto:admin@nexus.health

# ─── Sentry Error Tracking (I1) ──────────────────────────────────────────────────
# Get from https://sentry.io/ → Settings → Projects → Your Project → Client Keys
# Leave blank to disable Sentry (graceful no-op)
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@oNNNN.ingest.sentry.io/NNNNNN
# NEXT_PUBLIC_SENTRY_ENV=production   # override if needed; defaults to NODE_ENV

# ═══════════════════════════════════════════════════════════════════════════════
# NOTES:
# 1. NEXT_PUBLIC_* variables are exposed to the browser (don't put secrets there)
# 2. Private variables (no NEXT_PUBLIC_ prefix) are server-only
# 3. For local development, copy to .env.local (git-ignored)
# 4. For staging, copy to .env.staging (git-ignored)
# 5. For production, set in Vercel Environment Variables dashboard
# ═══════════════════════════════════════════════════════════════════════════════
