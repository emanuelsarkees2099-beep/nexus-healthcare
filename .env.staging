# ═══════════════════════════════════════════════════════════════════════════════
# NEXUS — Staging Environment
# I2: Staging-specific overrides for Vercel Preview deployments
#
# HOW TO USE:
#   Option A (Vercel): In the Vercel dashboard → Settings → Environment Variables,
#     add each variable and scope it to "Preview" environments only.
#
#   Option B (local): Copy to .env.local and swap values for your staging project.
#
# This file is git-safe — it contains no real secrets, only templates.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Node environment ────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── Supabase — STAGING project ──────────────────────────────────────────────────
# Point at a separate Supabase project (staging-nexus) to protect production data
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...staging-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...staging-service-role-key...

# I3 — Staging pgBouncer pooler URL (6543 = transaction mode, 5432 = session mode)
# SUPABASE_DATABASE_URL=postgresql://postgres.STAGING_PROJECT:[pw]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# SUPABASE_DIRECT_URL=postgresql://postgres.STAGING_PROJECT:[pw]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ─── Anthropic ───────────────────────────────────────────────────────────────────
# Can reuse the same key; Claude Haiku rate limits are generous
ANTHROPIC_API_KEY=sk-ant-v0-...

# ─── App identity ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://nexus-staging.vercel.app
NEXT_PUBLIC_APP_VERSION=nexus@staging
CRON_SECRET=staging-cron-secret-replace-me

# ─── Sentry ──────────────────────────────────────────────────────────────────────
# Use a separate Sentry project or the same DSN — staging events are labelled
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@oNNNN.ingest.sentry.io/NNNNNN
NEXT_PUBLIC_SENTRY_ENV=staging

# ─── Push notifications ───────────────────────────────────────────────────────────
# Use separate VAPID keys for staging so staging subscribers don't get production pushes
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BExampleStagingPublicKey...
VAPID_PRIVATE_KEY=ExampleStagingPrivateKey...
VAPID_SUBJECT=mailto:staging@nexus.health

# ─── Feature flags (staging-only) ────────────────────────────────────────────────
# These can enable/disable features in staging without touching production
# NEXT_PUBLIC_ENABLE_DEBUG_PANEL=true
# NEXT_PUBLIC_MOCK_CLINIC_DATA=false

# ─── Email ────────────────────────────────────────────────────────────────────────
# Staging digest emails go to a test inbox
# RESEND_API_KEY=re_staging_...
# DIGEST_EMAIL_TO=staging-team@nexus.health
